{
  "name": "choir-hub-server",
  "version": "1.0.0",
  "description": "Backend server for Choir Hub application",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "node dist/index.ts",
    "build": "tsc && tsc-alias",
    "dev": "bun --hot src/index.ts",
    "openapi-ts": "openapi-ts",
    "generate-prisma-client": "npx prisma generate",
    "run-db": "docker-compose up -d",
    "migrate-db": "prisma migrate dev --name init",
    "seed-db": "prisma db seed"
  },
  "dependencies": {
    "@better-auth/infra": "^0.1.11",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.5.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "helmet": "^8.1.0",
    "hono": "^4.12.8",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "winston": "^3.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.94.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.3.10",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.13",
    "@types/pg": "^8.18.0",
    "concurrently": "^8.2.2",
    "prisma": "^7.3.0",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2"
  }
}
